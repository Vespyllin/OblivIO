TEST

local channel PATH: err(path((_ * int@{h})@{h})[3]@{h});
local channel STR: err(string@{h});
local channel INT: err(int@{h});

var c: err(path((_ * int@{h})@{h})[3]@{h}) = onil(3);
var d: err(path((_ * int@{h})@{h})[3]@{h}) = onil(3);

START@{} (ignored: int@{}) {
    c = oram(
            (oram(
                (onil(3), 
            6), 3), 
        5), 3);
    d = fst(*c);
    
    output(INT, snd(*c));
    output(INT, snd(*d));
    output(STR, "ok");

    exit();
}
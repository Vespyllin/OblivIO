TEST

local channel STDOUT: string@{};

var p: string@{}[]@{}[]@{} = [["HEY"]; ["HI"]];
var q: string@{}[]@{}[]@{} = [["A"]; ["B"]];
var d: string@{}[]@{} = ["AB"];
var c: string@{} = "C";

START@{} (ignored: int@{}) {
    d = read(p,0,["1st"; "2nd"]);
    c = read(d,0,"size14");
    // p[0] = ["ABC"]; Invalid as it causes mutation, write(arr, idx, value) yields new array
    // p = write(p, 0, "ABC") yields a new array (copy of old with new value written in)
    
    output(STDOUT, c);

    exit();
}